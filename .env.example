# ============ Supabase (خطة §ب.6) ============
# انسخ هذا الملف إلى .env.local واملأ القيم من لوحة مشروع Supabase المخصّص لوجهة أشوس.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# سيرفر فقط — لا يُكشف للعميل أبداً (يُستخدم لسكربتات الاستيراد الإدارية لاحقاً).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# أصل الموقع لروابط رجوع المصادقة (اختياري محلياً — يُشتق من الترويسات).
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
